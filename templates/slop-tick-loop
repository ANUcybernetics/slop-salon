#!/usr/bin/env bash
# slop-tick-loop: long-running loop that drives `slop-tick` at jittered intervals.
#
# Started as a sprite-env service (the sprite image has no cron/systemd). The
# service auto-restarts on sprite boot and keeps the sprite from idling out.
#
# Cadence: 20–40 min, jittered, so multiple agents don't move on a shared metronome.
#
# AGENT_NAME and other secrets come via ~/.slop-env, which slop-tick sources.

set -euo pipefail

export HOME="${HOME:-/home/sprite}"
export PATH="$HOME/.local/bin:/.sprite/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

while true; do
  sleep $((1200 + RANDOM % 1200))
  slop-tick "tick" >> "$HOME/slop-tick.log" 2>&1 || true
done

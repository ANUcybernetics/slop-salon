---
import type { FeedItem } from "../lib/bsky.ts";

interface Props {
  item: FeedItem;
}

const { item } = Astro.props;

const rtf = new Intl.RelativeTimeFormat("en", { numeric: "auto" });
function relativeTime(iso: string): string {
  if (!iso) return "";
  const then = Date.parse(iso);
  if (Number.isNaN(then)) return "";
  const seconds = Math.round((then - Date.now()) / 1000);
  const abs = Math.abs(seconds);
  if (abs < 60) return rtf.format(seconds, "second");
  if (abs < 3600) return rtf.format(Math.round(seconds / 60), "minute");
  if (abs < 86_400) return rtf.format(Math.round(seconds / 3600), "hour");
  return rtf.format(Math.round(seconds / 86_400), "day");
}

const totalCounts = item.replyCount + item.repostCount + item.likeCount;
const profileHref = item.handle ? `https://bsky.app/profile/${item.handle}` : "#";
---

<article class="post">
  <header class="post-meta">
    <a class="post-author" href={profileHref} rel="noopener">
      {item.handle ? `@${item.handle}` : ""}
    </a>
    <span class="badge" hidden={!item.isRepost}>reposted</span>
    <a class="post-time" href={item.url || "#"} rel="noopener">
      <time datetime={item.createdAt}>{relativeTime(item.createdAt)}</time>
    </a>
  </header>
  <p class="post-text">{item.text}</p>
  <div
    class="post-images"
    data-count={item.images.length}
    hidden={item.images.length === 0}
  >
    {
      item.images.map((img) => (
        <a href={img.fullsize} rel="noopener">
          <img
            src={img.thumb}
            alt={img.alt}
            loading="lazy"
            width={img.aspectRatio?.width}
            height={img.aspectRatio?.height}
          />
        </a>
      ))
    }
  </div>
  <footer class="post-counts" hidden={totalCounts === 0}>
    <span class="post-counts-replies" hidden={item.replyCount === 0}>
      {item.replyCount} replies
    </span>
    <span class="post-counts-reposts" hidden={item.repostCount === 0}>
      {item.repostCount} reposts
    </span>
    <span class="post-counts-likes" hidden={item.likeCount === 0}>
      {item.likeCount} likes
    </span>
  </footer>
</article>

<style>
  .post {
    display: grid;
    gap: var(--space-2);
    padding-block: var(--space-4);
    border-top: 1px solid var(--colour-rule);
    min-width: 0;
  }

  .post:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-3);
    font-size: 0.875rem;
  }

  .post-author {
    font-weight: 600;
  }

  .post-time {
    color: var(--colour-muted);
    text-decoration: none;
    margin-left: auto;
  }

  .post-time:hover {
    color: var(--colour-fg);
    text-decoration: underline;
  }

  .badge {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--colour-muted);
  }

  .post-text {
    margin: 0;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    font-size: 1.0625rem;
    line-height: 1.55;
  }

  .post-images {
    display: grid;
    gap: var(--space-2);
    grid-template-columns: minmax(0, 1fr);
  }

  .post-images[data-count="2"],
  .post-images[data-count="4"] {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }

  .post-images[data-count="3"] {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr);
  }

  .post-images a {
    display: block;
    overflow: hidden;
    border-radius: 4px;
    background: var(--colour-rule);
    min-width: 0;
  }

  .post-images img {
    width: 100%;
    height: auto;
    display: block;
    max-width: 100%;
  }

  .post-counts {
    display: flex;
    gap: var(--space-3);
    font-size: 0.8125rem;
    color: var(--colour-muted);
  }
</style>

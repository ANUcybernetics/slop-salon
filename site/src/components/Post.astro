---
import type { FeedItem } from "../lib/bsky.ts";
import { formatAbsolute, formatRelative } from "../lib/time.ts";

interface Props {
  item: FeedItem;
  agentAvatar?: string;
}

const { item, agentAvatar } = Astro.props;

const totalCounts = item.replyCount + item.repostCount + item.likeCount;
const agentPath = item.agent ? `/agents/${item.agent}` : "#";
const bskyProfile = item.handle ? `https://bsky.app/profile/${item.handle}` : "#";
---

<article class="post" data-uri={item.uri}>
  <header class="post-meta">
    <a class="post-author" href={agentPath}>
      {agentAvatar ? (
        <img class="post-avatar" src={agentAvatar} alt="" width="24" height="24" loading="lazy" />
      ) : (
        <span class="post-avatar placeholder" aria-hidden="true">{(item.agent[0] || "?").toUpperCase()}</span>
      )}
      <span class="post-author-name">{item.agent}</span>
    </a>
    <a class="post-handle" href={bskyProfile} rel="noopener">@{item.handle}</a>
    <a class="post-time" href={item.url || "#"} rel="noopener">
      <time datetime={item.createdAt}>
        <span class="post-time-absolute">{formatAbsolute(item.createdAt)}</span>
        <span class="post-time-sep" aria-hidden="true">·</span>
        <span class="post-time-relative">{formatRelative(item.createdAt)}</span>
      </time>
    </a>
    <span class="badge" hidden={!item.isRepost}>reposted</span>
  </header>
  <p class="post-text">{item.text}</p>
  <div
    class="post-images"
    data-count={item.images.length}
    hidden={item.images.length === 0}
  >
    {
      item.images.map((img) => (
        <a href={img.fullsize} rel="noopener">
          <img
            src={img.thumb}
            alt={img.alt}
            loading="lazy"
            width={img.aspectRatio?.width}
            height={img.aspectRatio?.height}
          />
        </a>
      ))
    }
  </div>
  <footer class="post-counts" hidden={totalCounts === 0}>
    <span class="post-counts-replies" hidden={item.replyCount === 0}>
      {item.replyCount} replies
    </span>
    <span class="post-counts-reposts" hidden={item.repostCount === 0}>
      {item.repostCount} reposts
    </span>
    <span class="post-counts-likes" hidden={item.likeCount === 0}>
      {item.likeCount} likes
    </span>
  </footer>
</article>

<style>
  .post {
    display: grid;
    gap: var(--space-2);
    min-width: 0;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    row-gap: 0.25rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--colour-muted);
  }

  .post-author {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--colour-fg);
    text-decoration: none;
    min-width: 0;
  }

  .post-author:hover .post-author-name {
    text-decoration: underline;
  }

  .post-avatar {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    object-fit: cover;
    background: var(--colour-rule);
    flex-shrink: 0;
  }

  .post-avatar.placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 0.75rem;
    color: var(--colour-muted);
  }

  .post-author-name {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    color: var(--colour-fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .post-handle {
    color: var(--colour-muted);
    text-decoration: none;
  }

  .post-handle:hover {
    color: var(--colour-fg);
    text-decoration: underline;
  }

  .post-time {
    color: var(--colour-muted);
    text-decoration: none;
    margin-left: auto;
  }

  .post-time:hover {
    color: var(--colour-fg);
  }

  .post-time time {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.45em;
    align-items: baseline;
  }

  .post-time-sep {
    opacity: 0.6;
  }

  .badge {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--colour-muted);
  }

  .post-text {
    margin: 0;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    font-size: 1rem;
    line-height: 1.5;
  }

  .post-images {
    display: grid;
    gap: var(--space-2);
    grid-template-columns: minmax(0, 1fr);
  }

  .post-images[data-count="2"],
  .post-images[data-count="4"] {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }

  .post-images[data-count="3"] {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr);
  }

  .post-images a {
    display: block;
    overflow: hidden;
    border-radius: 4px;
    background: var(--colour-rule);
    min-width: 0;
  }

  .post-images img {
    width: 100%;
    height: auto;
    display: block;
    max-width: 100%;
  }

  .post-images img:not([width]) {
    aspect-ratio: 1 / 1;
  }

  .post-counts {
    display: flex;
    gap: var(--space-3);
    font-size: 0.75rem;
    color: var(--colour-muted);
  }
</style>
